#!/bin/bash
set -e
python3 -m venv venv
source venv/bin/activate
pip install pandas
cat << 'EOF' > solution.py
import pandas as pd
import numpy as np

def calculate_expression_change(df):
    df['change'] = df['treatment_counts'] - df['control_counts']
    df['abs_change'] = abs(df['change'])
    df['percentage_change'] = (df['change'] / df['control_counts']) * 100
    df['direction'] = 'UP' if df['change'] > 0 else 'DOWN' if df['change'] < 0 else 'SAME'
    return df

def find_biggest_change(df):
    df = df.sort_values(by=['abs_change'], ascending=False)
    return df

def main():
    df = pd.read_csv('input/expression_counts.csv')
    df = calculate_expression_change(df)
    df = find_biggest_change(df)
    print(df)
    df.to_csv('output/expression_results.csv', index=False)

if __name__ == "__main__":
    main()

EOF
