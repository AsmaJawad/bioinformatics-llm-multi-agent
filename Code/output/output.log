import pandas as pd

def load_expression_data():
    data = pd.read_csv('input/expression_counts.csv', usecols=['gene_id', 'gene_name', 'length', 'control_1', 'control_2', 'control_3', 'treatment_1', 'treatment_2', 'treatment_3'])
    return data

def compute_per_group_means(data):
    data['control_mean'] = data[['control_1', 'control_2', 'control_3']].mean(axis=1)
    data['treatment_mean'] = data[['treatment_1', 'treatment_2', 'treatment_3']].mean(axis=1)
    return data

def classify_and_report_fold_change(data):
    data['fold_change'] = data['treatment_mean'] / data['control_mean']
    data['label'] = 'UP' if data['fold_change'] > 1.5 else ('DOWN' if data['fold_change'] < 0.67 else 'SAME')
    data['change_multiplier'] = data['fold_change']
    data = data.sort_values(by='fold_change', ascending=False)
    return data

def main():
    data = load_expression_data()
    data = compute_per_group_means(data)
    data = classify_and_report_fold_change(data)
    for index, row in data.iterrows():
        print(f"{row['gene_name']}: {row['control_mean']}, {row['treatment_mean']}, {row['label']}, {row['change_multiplier']}")

if __name__ == '__main__':
    main()
