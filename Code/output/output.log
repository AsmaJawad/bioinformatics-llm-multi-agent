    df['label'] = 'UP' if df['fold_change'] > 1.5 else 'DOWN' if df['fold_change'] < 0.67 else 'SAME'
    df = df.sort_values(by='fold_change', ascending=False)
    df['multiplier'] = df['treatment_mean'] / df['control_mean']
    return df

def main():
    df = load_expression_data()
    df = compute_per_group_means(df)
    df = classify_and_report_fold_change(df)
    for index, row in df.iterrows():
        print(f"{row['gene_name']}\t{row['control_mean']}\t{row['treatment_mean']}\t{row['label']}\t{row['multiplier']}")

if __name__ == '__main__':
    try:
        main()
    except Exception as e:
        print(f"An error occurred: {e}")

