import pandas as pd
import sys

# Load and inspect the input CSV file using pandas
def inspect_data():
    try:
        df = pd.read_csv('input/expression_counts.csv')
        print(df.head())
    except FileNotFoundError:
        print("Error: File not found", file=sys.stderr)
        sys.exit(1)

# Calculate the average expression for each gene in the control and treatment samples using pandas
def normalize_data():
    try:
        df = pd.read_csv('input/expression_counts.csv')
        df_control = df[df['sample'] == 'control']
        df_treatment = df[df['sample'] == 'treatment']
        avg_control = df_control.mean()
        avg_treatment = df_treatment.mean()
        return avg_control, avg_treatment
    except Exception as e:
        print(f"Error occurred: {e}", file=sys.stderr)
        sys.exit(1)

# Compare the average expression of each gene between the control and treatment samples using pandas
def compare_data(avg_control, avg_treatment):
    try:
        result = {}
        for gene in avg_control.index:
            if gene in avg_treatment.index:
                if avg_control.loc[gene] > avg_treatment.loc[gene]:
                    result[gene] = 'UP'
                elif avg_control.loc[gene] < avg_treatment.loc[gene]:
                    result[gene] = 'DOWN'
                else:
                    result[gene] = 'SAME'
        return result
    except Exception as e:
        print(f"Error occurred: {e}", file=sys.stderr)
        sys.exit(1)

# Determine if the gene expression is UP, DOWN, or the SAME, and by how many times using pandas
def aggregate_data(result):
    try:
        for gene, status in result.items():
            if status == 'UP':
                print(f"{gene}: {result[gene]} x {abs(avg_control.loc[gene] - avg_treatment.loc[gene])}")
            elif status == 'DOWN':
                print(f"{gene}: {result[gene]} x {abs(avg_control.loc[gene] - avg_treatment.loc[gene])}")
            else:
                print(f"{gene}: {result[gene]} x 1")
    except Exception as e:
        print(f"Error occurred: {e}", file=sys.stderr)
        sys.exit(1)

inspect_data()
avg_control, avg_treatment = normalize_data()
result = compare_data(avg_control, avg_treatment)
aggregate_data(result)
deactivate

