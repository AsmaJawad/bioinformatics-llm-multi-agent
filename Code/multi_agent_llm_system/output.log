#!/bin/bash
set -e
python3 -m venv venv
source venv/bin/activate
pip install biopython sys json
cat << 'EOF' > solution.py
from Bio import SeqIO
from collections import defaultdict
from sys import exit

def calculate_molecular_weight(seq):
    molecular_weight = 0
    amino_acid_composition = defaultdict(int)
    for amino_acid in seq:
        molecular_weight += amino_acid.molecular_weight
        amino_acid_composition[amino_acid.name] += 1
    return molecular_weight, amino_acid_composition

def count_cysteine(seq):
    return seq.count('C')

def find_disulfide_bonds(seq):
    disulfide_bonds = []
    for i in range(len(seq) - 2):
        if seq[i] == 'C' and seq[i+2] == 'C':
            disulfide_bonds.append((i, i+2))
    return disulfide_bonds

with open('proteins.fasta', 'r') as handle:
    for record in SeqIO.parse(handle, 'fasta'):
        id = record.id
        seq = str(record.seq)
        molecular_weight, amino_acid_composition = calculate_molecular_weight(seq)
        cysteine_count = count_cysteine(seq)
        disulfide_bonds = find_disulfide_bonds(seq)
        print(f'ID: {id}')
        print(f'Molecular Weight: {molecular_weight}')
        print(f'Amino Acid Composition: {amino_acid_composition}')
        print(f'Cysteine Count: {cysteine_count}')
        print(f'Disulfide Bonds: {disulfide_bonds}')
        print('')

deactivate

