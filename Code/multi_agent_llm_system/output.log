#!/bin/bash

# set -e to exit immediately on errors
set -e

# create and activate a virtual environment
python3 -m venv venv
source venv/bin/activate

# install required libraries
pip install biopython pandas

# write the python code
cat << 'EOF' > solution.py
import pandas as pd
from Bio import SeqIO
from collections import Counter

# read fasta file
records = SeqIO.parse('proteins.fasta', 'fasta')

# write the results to a file
with open('output.txt', 'w') as out:
    for record in records:
        id = record.id
        molecular_weight = len(record.seq) * 110  # 110 is the average molecular weight of an amino acid
        amino_acid_composition = dict(Counter(record.seq))
        cysteine_count = amino_acid_composition.get('C', 0)
        disulfide_bonds = [i for i in range(len(record.seq) - 2) if record.seq[i] == 'C' and record.seq[i+1] == 'X' and record.seq[i+2] == 'C']
        
        out.write(f"ID: {id}\nMolecular Weight: {molecular_weight}\nAmino Acid Composition: {amino_acid_composition}\nCysteine Count: {cysteine_count}\nDisulfide Bonds: {disulfide_bonds}\n\n")

# execute the python script
python3 solution.py

# deactivate and remove the venv
deactivate
rm -rf venv

