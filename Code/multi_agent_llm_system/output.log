#!/bin/bash

# Setup
set -e
python3 -m venv venv
source venv/bin/activate

pip install requests biopython pandas

# File path
file_path="proteins.fasta"

# Translation
cat << "EOF" > translation.py
import requests
import re
import pandas as pd

ids = ['sp|P04637|P53_HUMAN']
urls = [f"https://www.uniprot.org/uniprot/{id.split('|')[0]}?format=fasta" for id in ids]
sequences = [requests.get(url).text for url in urls]

with open(file_path, 'r') as f:
    lines = f.read().strip().split('\n')

sequences = [re.sub(r'(.*)\n', r'\1', line) for line in lines if line.startswith('>')]
sequences = [seq.replace('\n', '') for seq in sequences]

print(sequences)
EOF

python3 translation.py

# Molecular Weight Calculation
cat << "EOF" > molecular_weight_calculation.py
import Bio.SeqUtils
import pandas as pd

sequences = ['ATCGATCGATCG', 'ATCGATCGATCG']

df = pd.DataFrame({'sequence': sequences})
df['weight'] = df['sequence'].apply(Bio.SeqUtils.molecular_weight)

print(df)
EOF

python3 molecular_weight_calculation.py

# Amino Acid Composition
cat << "EOF" > amino_acid_composition.py
import Bio.SeqUtils
import pandas as pd

sequences = ['ATCGATCGATCG', 'ATCGATCGATCG']

df = pd.DataFrame({'sequence': sequences})
df['composition'] = df['sequence'].apply(Bio.SeqUtils.aaindex.pchem_composition)

print(df)
EOF

python3 amino_acid_composition.py

# Max Cysteine Protein
cat << "EOF" > max_cysteine_protein.py
import pandas as pd

sequences = ['ATCGATCGATCG', 'ATCGATCGATCG']

df = pd.DataFrame({'sequence': sequences})
df['cysteine_count'] = df['sequence'].apply(lambda x: x.count('C'))

max_cysteine_protein = df.loc[df['cysteine_count'].idxmax()]['sequence']

print(max_cysteine_protein)
EOF

python3 max_cysteine_protein.py

# Disulfide Bond Motif Search
cat << "EOF" > disulfide_bond_motif_search.py
import pandas as pd

sequences = ['ATCGATCGATCG', 'ATCGATCGATCG']

df = pd.DataFrame({'sequence': sequences})
df['motifs'] = df['sequence'].apply(lambda x: [i for i in range(len(x)) if x[i:i+3] == 'CXC'])

