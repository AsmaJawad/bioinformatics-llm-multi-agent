from Bio import SeqIO
from collections import Counter
from sys import exit

def calculate_molecular_weight(sequence):
    molecular_weight = 0
    for amino_acid in sequence:
        molecular_weight += amino_acid.molecular_weight
    return molecular_weight

def calculate_amino_acid_composition(sequence):
    amino_acid_composition = Counter(sequence)
    return amino_acid_composition

def main():
    for record in SeqIO.parse('proteins.fasta', 'fasta'):
        sequence = record.seq
        molecular_weight = calculate_molecular_weight(sequence)
        amino_acid_composition = calculate_amino_acid_composition(sequence)
        print(f'Molecular weight: {molecular_weight}, Amino acid composition: {amino_acid_composition}')

if __name__ == "__main__":
    try:
        main()
    except Exception as e:
        print(f"An error occurred: {e}")

